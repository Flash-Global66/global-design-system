{
  "name": "@flash-global66/global-design-system",
  "version": "0.0.1",
  "main": "index.js",
  "type": "module",
  "repository": {
    "url": "https://github.com/Flash-Global66/global-design-system.git"
  },
  "private": true,
  "workspaces": [
    "components/*",
    "common/*"
  ],
  "author": "Global66",
  "license": "MIT",
  "resolutions": {
    "jest-mock": "^28.1.0",
    "sass": "^1.79.0"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com/@flash-global"
  },
  "scripts": {
    "prepare": "simple-git-hooks",
    "storybook": "storybook dev -p 6006 --ci",
    "build-storybook": "storybook build",
    "diff": "npx lerna diff",
    "compare-versions": "bash ./scripts-terminal/generate-versions-local.sh && bash ./scripts-terminal/compare-versions.sh",
    "sync-versions": "bash ./scripts-terminal/sync-versions.sh",
    "reset-tags": "bash ./scripts-terminal/reset-tags.sh",
    "build": "node scripts/build-components.js",
    "build:types": "npx lerna run build:types --scope \"@flash-global66/g-*\"",
    "build:publish": "yarn build && yarn publish",
    "format": "prettier --write --cache .",
    "format:check": "prettier --check --cache .",
    "lint": "eslint . --ext .vue,.ts,.js --cache --max-warnings 0",
    "lint:fix": "eslint . --ext .vue,.ts,.js --fix",
    "test": "vitest run",
    "test:run": "vitest run",
    "test:watch": "vitest"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "lint-staged": {
    "*.{vue,ts,js,jsx,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{scss,md,json,yaml,yml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@element-plus/utils": "0.0.5",
    "@fortawesome/fontawesome-common-types": "6.7.2",
    "@popperjs/core": "2.11.8",
    "@storybook/manager-api": "8.6.14",
    "@vueuse/core": "13.0.0",
    "async-validator": "4.2.5",
    "autoprefixer": "10.4.21",
    "element-plus": "2.9.7",
    "lodash-unified": "1.0.3",
    "vue-router": "4.5.1"
  },
  "devDependencies": {
    "@babel/core": "7.28.3",
    "@fortawesome/fontawesome-svg-core": "6.7.2",
    "@fortawesome/vue-fontawesome": "3.1.1",
    "@storybook/addon-actions": "8.6.14",
    "@storybook/addon-controls": "8.6.14",
    "@storybook/addon-essentials": "8.4.7",
    "@storybook/addon-interactions": "8.4.7",
    "@storybook/addon-jest": "8.6.14",
    "@storybook/addon-links": "8.6.14",
    "@storybook/addon-postcss": "2.0.0",
    "@storybook/test": "8.4.7",
    "@storybook/vue3": "8.6.14",
    "@storybook/vue3-vite": "8.4.7",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/vue": "^8.1.0",
    "@vitejs/plugin-vue": "5.2.4",
    "@vue/eslint-config-typescript": "^13",
    "babel-loader": "8.4.1",
    "eslint": "8.57.1",
    "eslint-config-prettier": "9.1.0",
    "eslint-plugin-vue": "9",
    "jest-mock": "28.1.3",
    "jsdom": "^29.1.1",
    "lerna": "8.2.4",
    "lint-staged": "16.1.2",
    "prettier": "3.6.2",
    "rollup-plugin-copy": "3.5.0",
    "sass": "1.90.0",
    "simple-git-hooks": "2.13.0",
    "storybook": "8.6.14",
    "tailwindcss": "3.4.17",
    "typescript": "5.9.2",
    "vite": "5.2.11",
    "vite-dts": "1.0.4",
    "vitest": "2",
    "vue": "3.5.18",
    "vue-currency-input": "3.2.2",
    "vue-loader": "16.8.3",
    "vue-tsc": "2.2.12"
  },
  "packageManager": "yarn@4.11.0"
}
