{
  "name": "@flash-global66/g-logo",
  "version": "0.0.16",
  "description": "Logos de Global66 y, progresivamente, de aliados y proveedores (PSE, Bancolombia, Bre-B, etc.) con tamaños y filtros CSS",
  "author": "Global66",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/types/index.d.ts",
  "buildable": true,
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/types/index.d.ts"
    },
    "./styles.scss": "./src/logo.styles.scss",
    "./*": "./*"
  },
  "files": [
    "dist",
    "src",
    "index.ts"
  ],
  "scripts": {
    "build": "vite build",
    "build:types": "vue-tsc --project tsconfig.json"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "url": "https://github.com/Flash-Global66/global-design-system.git"
  },
  "dependencies": {
    "@flash-global66/g-utils": "^0.13.0"
  },
  "peerDependencies": {
    "@vueuse/core": "^13.0.0",
    "element-plus": "^2.0.0",
    "vue": "^3.2.0"
  }
}
